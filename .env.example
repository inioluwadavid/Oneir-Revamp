# Resend (https://resend.com) — required for demo modal submissions
RESEND_API_KEY=
# Verified sender in Resend (use onboarding@resend.dev for testing)
RESEND_FROM=onboarding@resend.dev
# Inbox that receives demo form submissions
DEMO_REQUEST_TO=ajidaveini@gmail.com

# Cloudinary — optional; demo modal uploads use an UNSIGNED upload preset (Settings → Upload → Upload presets)
# https://cloudinary.com/documentation/upload_presets
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Google Analytics (GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
